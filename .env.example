# ── Database ──────────────────────────────────────────────────────────────────
# Neon Postgres connection string
# Get it from: https://console.neon.tech
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Clerk Auth ────────────────────────────────────────────────────────────────
# Get these from: https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect paths (defaults, change if needed)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── AWS ───────────────────────────────────────────────────────────────────────
# IAM user with s3:PutObject, s3:GetObject, s3:DeleteObject, s3:RestoreObject, s3:HeadObject
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
AWS_S3_BUCKET=archivault-prod

# ── Upstash QStash ────────────────────────────────────────────────────────────
# Get these from: https://console.upstash.com → QStash
QSTASH_URL=https://qstash.upstash.io
QSTASH_TOKEN=...
QSTASH_CURRENT_SIGNING_KEY=...
QSTASH_NEXT_SIGNING_KEY=...

# ── Resend (email) ────────────────────────────────────────────────────────────
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_...
# Verified sender address in your Resend account
RESEND_FROM_EMAIL=Archivault <noreply@archivault.app>

# ── Stripe (billing) ──────────────────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs — create one recurring price per plan in your Stripe dashboard
STRIPE_PRICE_ID_STARTER=price_...
STRIPE_PRICE_ID_PERSONAL=price_...
STRIPE_PRICE_ID_CREATOR=price_...
STRIPE_PRICE_ID_POWER=price_...

# ── OneDrive (MVP 5 — Import) ─────────────────────────────────────────────────
# Register an app at https://portal.azure.com → Microsoft Entra ID → App registrations
# → New registration → Redirect URI: http://localhost:3000/api/auth/onedrive/callback
# Add API permissions: Microsoft Graph → Delegated → Files.Read
ONEDRIVE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ONEDRIVE_CLIENT_SECRET=...
ONEDRIVE_REDIRECT_URI=http://localhost:3000/api/auth/onedrive/callback

# ── Google Drive (MVP 4 — Import) ─────────────────────────────────────────────
# Create a project at https://console.cloud.google.com → Enable Google Drive API
# → OAuth 2.0 credentials → Web application type
# Authorized redirect URIs: http://localhost:3000/api/auth/google/callback (dev)
#                           https://your-domain.com/api/auth/google/callback (prod)
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ── App ───────────────────────────────────────────────────────────────────────
# Your deployed URL (used to build absolute webhook URLs for QStash)
NEXT_PUBLIC_APP_URL=http://localhost:3000
